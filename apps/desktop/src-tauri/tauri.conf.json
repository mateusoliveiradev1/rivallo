{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rivallo",
  "version": "0.1.0",
  "identifier": "com.rivallo.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @rivallo/desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @rivallo/desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rivallo",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "fullscreen": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "externalBin": ["binaries/local_api"]
  }
}
