{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rivallo.local/schemas/package-manifest.v3.json",
  "title": "Rivallo package manifest v3 (reads v1 and v2)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packageId",
    "name",
    "version",
    "schemaVersion",
    "gameVersionCompatibility",
    "author",
    "description",
    "contentType",
    "dependencies",
    "conflicts",
    "loadOrderHint",
    "entrypoints",
    "assets",
    "provenance",
    "visibility",
    "checksum"
  ],
  "properties": {
    "packageId": { "$ref": "#/$defs/stableId" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "schemaVersion": { "enum": [1, 2, 3] },
    "compositionMode": { "enum": ["additive", "authoritative"], "default": "additive" },
    "targetBaseFingerprint": {
      "oneOf": [{ "type": "string", "pattern": "^[a-f0-9]{16}$" }, { "type": "null" }]
    },
    "authoritativeScopes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "clubs",
          "competitions",
          "competitionParticipants",
          "sportingPeople",
          "registrations",
          "contracts",
          "playerProfiles",
          "coachProfiles",
          "externalPlayers",
          "assessments",
          "attributeHistory",
          "matchdayState",
          "stadiums",
          "assets",
          "translations",
          "positions",
          "roles",
          "attributes",
          "traits",
          "projections"
        ]
      }
    },
    "sidecars": { "type": "array", "items": { "$ref": "#/$defs/sidecar" } },
    "compatibility": { "$ref": "#/$defs/compatibility" },
    "changelog": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "gameVersionCompatibility": { "type": "string", "minLength": 1, "maxLength": 80 },
    "author": { "type": "string", "minLength": 1, "maxLength": 120 },
    "description": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "contentType": { "enum": ["base", "mod"] },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packageId", "versionRequirement", "optional"],
        "properties": {
          "packageId": { "$ref": "#/$defs/stableId" },
          "versionRequirement": { "type": "string", "minLength": 1, "maxLength": 80 },
          "optional": { "type": "boolean" }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packageId", "reason"],
        "properties": {
          "packageId": { "$ref": "#/$defs/stableId" },
          "reason": { "type": "string", "minLength": 1, "maxLength": 500 }
        }
      }
    },
    "loadOrderHint": { "type": "integer", "minimum": -100000, "maximum": 100000 },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["world"],
      "properties": {
        "world": { "$ref": "#/$defs/relativePath" },
        "patches": { "oneOf": [{ "$ref": "#/$defs/relativePath" }, { "type": "null" }] },
        "assets": { "oneOf": [{ "$ref": "#/$defs/relativePath" }, { "type": "null" }] }
      }
    },
    "assets": { "type": "array", "items": { "$ref": "world-package.schema.json#/$defs/asset" } },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "rights", "createdAt"],
      "properties": {
        "source": { "type": "string", "minLength": 1, "maxLength": 500 },
        "rights": { "type": "string", "minLength": 1, "maxLength": 500 },
        "createdAt": { "type": "string", "format": "date" },
        "notes": { "type": ["string", "null"], "maxLength": 1000 }
      }
    },
    "visibility": { "enum": ["public", "privateDevelopment"] },
    "checksum": { "type": "string", "pattern": "^(?:sha256:)?[a-f0-9]{64}$" }
  },
  "$defs": {
    "stableId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,159}$" },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 260,
      "pattern": "^(?![\\\\/])(?!.*\\.\\.)(?!.*:).+$"
    },
    "sidecar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "version", "relativePath", "byteLength", "sha256", "required"],
      "properties": {
        "kind": { "enum": ["evaluationLayer", "assetLayer", "provenance", "extension"] },
        "version": { "type": "integer", "minimum": 1 },
        "relativePath": { "$ref": "#/$defs/relativePath" },
        "byteLength": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "required": { "type": "boolean" },
        "compatibility": { "type": ["string", "null"] }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtimeProfile": { "type": ["string", "null"] },
        "minimumGameVersion": { "type": ["string", "null"] }
      }
    }
  }
}
