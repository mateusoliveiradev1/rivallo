{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rivallo.local/schemas/world-package.v1.json",
  "title": "Rivallo world package v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "matchday",
    "profiles",
    "clubs",
    "nations",
    "regions",
    "cities",
    "stadiums",
    "competitions",
    "positions",
    "roles",
    "attributes",
    "traits",
    "assets"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "matchday": { "type": "object" },
    "profiles": { "type": "object" },
    "clubs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "shortName", "city", "primaryColor"],
        "properties": {
          "id": { "$ref": "#/$defs/stableId" },
          "name": { "$ref": "#/$defs/name" },
          "shortName": { "type": "string", "minLength": 1, "maxLength": 8 },
          "city": { "type": "string", "minLength": 1, "maxLength": 160 },
          "primaryColor": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "countryCode": { "type": ["string", "null"], "maxLength": 3 },
          "competitionName": { "type": ["string", "null"], "maxLength": 160 },
          "stadiumName": { "type": ["string", "null"], "maxLength": 160 },
          "nationId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] },
          "cityId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] },
          "competitionId": {
            "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }]
          },
          "stadiumId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] },
          "crestAssetId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] },
          "historySummary": { "type": ["string", "null"], "maxLength": 1200 }
        }
      }
    },
    "nations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "iso2", "iso3"],
        "properties": {
          "id": { "$ref": "#/$defs/stableId" },
          "name": { "$ref": "#/$defs/name" },
          "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "iso3": { "type": "string", "pattern": "^[A-Z]{3}$" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "confederationId": { "type": ["string", "null"] },
          "flagAssetId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] },
          "externalIds": { "type": "array", "items": { "$ref": "#/$defs/externalId" } }
        }
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "nationId", "name"],
        "properties": {
          "id": { "$ref": "#/$defs/stableId" },
          "nationId": { "$ref": "#/$defs/stableId" },
          "name": { "$ref": "#/$defs/name" }
        }
      }
    },
    "cities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "nationId", "name"],
        "properties": {
          "id": { "$ref": "#/$defs/stableId" },
          "nationId": { "$ref": "#/$defs/stableId" },
          "regionId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] },
          "name": { "$ref": "#/$defs/name" }
        }
      }
    },
    "stadiums": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "cityId", "capacity"],
        "properties": {
          "id": { "$ref": "#/$defs/stableId" },
          "name": { "$ref": "#/$defs/name" },
          "cityId": { "$ref": "#/$defs/stableId" },
          "ownerClubId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] },
          "capacity": { "type": "integer", "minimum": 1, "maximum": 250000 },
          "assetId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] }
        }
      }
    },
    "competitions": {
      "type": "array",
      "items": { "$ref": "#/$defs/competition" }
    },
    "positions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "abbreviation"],
        "properties": {
          "id": { "enum": ["GK", "RB", "CB", "LB", "DM", "CM", "AM", "RW", "LW", "ST"] },
          "label": { "$ref": "#/$defs/name" },
          "abbreviation": { "type": "string", "minLength": 1, "maxLength": 8 }
        }
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "positionId", "label"],
        "properties": {
          "id": { "$ref": "#/$defs/stableId" },
          "positionId": { "enum": ["GK", "RB", "CB", "LB", "DM", "CM", "AM", "RW", "LW", "ST"] },
          "label": { "$ref": "#/$defs/name" },
          "responsibilities": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "attributes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "category", "minimum", "maximum"],
        "properties": {
          "id": { "$ref": "#/$defs/stableId" },
          "label": { "$ref": "#/$defs/name" },
          "category": { "$ref": "#/$defs/name" },
          "minimum": { "type": "integer", "minimum": 0, "maximum": 255 },
          "maximum": { "type": "integer", "minimum": 0, "maximum": 255 }
        }
      }
    },
    "traits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "description"],
        "properties": {
          "id": { "$ref": "#/$defs/stableId" },
          "label": { "$ref": "#/$defs/name" },
          "description": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    },
    "assets": { "type": "array", "items": { "$ref": "#/$defs/asset" } }
  },
  "$defs": {
    "stableId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,159}$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 160 },
    "externalId": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "externalId"],
      "properties": {
        "source": { "type": "string", "minLength": 1, "maxLength": 120 },
        "externalId": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "competition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "shortName", "nationId", "seasons"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/name" },
        "shortName": { "$ref": "#/$defs/name" },
        "nationId": { "$ref": "#/$defs/stableId" },
        "regionId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] },
        "logoAssetId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] },
        "category": { "type": ["string", "null"], "maxLength": 80 },
        "level": { "type": ["integer", "null"], "minimum": 1, "maximum": 20 },
        "description": { "type": ["string", "null"], "maxLength": 1200 },
        "primaryColor": { "type": ["string", "null"], "pattern": "^#[0-9A-Fa-f]{6}$" },
        "secondaryColor": { "type": ["string", "null"], "pattern": "^#[0-9A-Fa-f]{6}$" },
        "baseSeasonId": { "oneOf": [{ "$ref": "#/$defs/stableId" }, { "type": "null" }] },
        "seasons": { "type": "array", "items": { "$ref": "#/$defs/season" } }
      }
    },
    "season": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "competitionId",
        "label",
        "startDate",
        "endDate",
        "rules",
        "participantClubIds"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "competitionId": { "$ref": "#/$defs/stableId" },
        "label": { "$ref": "#/$defs/name" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "rules": { "$ref": "#/$defs/competitionRules" },
        "participantClubIds": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stableId" }
        },
        "stages": { "type": "array", "items": { "$ref": "#/$defs/competitionStage" } },
        "registrationWindows": { "type": "array", "items": { "$ref": "#/$defs/dateWindow" } },
        "calendarConstraints": { "$ref": "#/$defs/calendarConstraints" },
        "playerRegistrations": {
          "type": "array",
          "items": { "$ref": "#/$defs/playerRegistration" }
        }
      }
    },
    "competitionRules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pointsForWin",
        "pointsForDraw",
        "pointsForLoss",
        "participantCount",
        "rounds",
        "legs",
        "tieBreakers"
      ],
      "properties": {
        "pointsForWin": { "type": "integer", "minimum": 0, "maximum": 10 },
        "pointsForDraw": { "type": "integer", "minimum": 0, "maximum": 10 },
        "pointsForLoss": { "type": "integer", "minimum": 0, "maximum": 10 },
        "participantCount": { "type": "integer", "minimum": 2, "maximum": 512 },
        "rounds": { "type": "integer", "minimum": 1, "maximum": 1024 },
        "legs": { "type": "integer", "minimum": 1, "maximum": 4 },
        "tieBreakers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 80 }
        },
        "minimumRosterSize": { "type": "integer", "minimum": 11, "maximum": 100 },
        "minimumGoalkeepers": { "type": "integer", "minimum": 1, "maximum": 10 },
        "starters": { "type": "integer", "minimum": 5, "maximum": 15 },
        "benchSize": { "type": "integer", "minimum": 0, "maximum": 30 },
        "substitutions": { "type": "integer", "minimum": 0, "maximum": 15 },
        "extraTime": { "type": "boolean" },
        "penalties": { "type": "boolean" },
        "foreignPlayerLimit": { "type": ["integer", "null"], "minimum": 0, "maximum": 99 },
        "minimumHomegrownPlayers": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 99
        },
        "promotionSlots": { "type": "integer", "minimum": 0, "maximum": 99 },
        "relegationSlots": { "type": "integer", "minimum": 0, "maximum": 99 }
      }
    },
    "competitionStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "order", "kind", "participantCount"],
      "properties": {
        "id": { "$ref": "#/$defs/stableId" },
        "name": { "$ref": "#/$defs/name" },
        "order": { "type": "integer", "minimum": 1, "maximum": 100 },
        "kind": {
          "enum": [
            "roundRobin",
            "doubleRoundRobin",
            "groups",
            "knockout",
            "twoLeggedKnockout",
            "singleFinal",
            "qualifying"
          ]
        },
        "participantCount": { "type": "integer", "minimum": 2, "maximum": 512 },
        "groupCount": { "type": "integer", "minimum": 0, "maximum": 128 },
        "legs": { "type": "integer", "minimum": 1, "maximum": 4 },
        "advanceCount": { "type": "integer", "minimum": 0, "maximum": 512 },
        "eliminateCount": { "type": "integer", "minimum": 0, "maximum": 512 },
        "pointsForWin": { "type": ["integer", "null"], "minimum": 0, "maximum": 10 },
        "pointsForDraw": { "type": ["integer", "null"], "minimum": 0, "maximum": 10 },
        "pointsForLoss": { "type": ["integer", "null"], "minimum": 0, "maximum": 10 },
        "tieBreakers": { "type": "array", "items": { "type": "string", "maxLength": 80 } },
        "extraTime": { "type": "boolean" },
        "penalties": { "type": "boolean" },
        "neutralVenue": { "type": "boolean" }
      }
    },
    "dateWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startDate", "endDate"],
      "properties": {
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" }
      }
    },
    "calendarConstraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preferredWeekdays": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1, "maximum": 7 }
        },
        "kickoffTimes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" }
        },
        "minimumRestDays": { "type": "integer", "minimum": 0, "maximum": 30 },
        "blockedDates": { "type": "array", "items": { "type": "string", "format": "date" } },
        "neutralVenue": { "type": "boolean" }
      }
    },
    "playerRegistration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["playerId", "clubId", "eligible"],
      "properties": {
        "playerId": { "$ref": "#/$defs/stableId" },
        "clubId": { "$ref": "#/$defs/stableId" },
        "shirtNumber": { "type": ["integer", "null"], "minimum": 1, "maximum": 999 },
        "contractReference": { "type": ["string", "null"], "maxLength": 160 },
        "eligible": { "type": "boolean" }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "path",
        "mediaType",
        "checksum",
        "provenance",
        "rights",
        "privateUse"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "entityId": { "type": ["string", "null"], "minLength": 1, "maxLength": 160 },
        "kind": { "type": "string", "minLength": 1, "maxLength": 80 },
        "path": { "type": "string", "minLength": 1, "maxLength": 260 },
        "mediaType": { "enum": ["image/png", "image/webp", "image/jpeg", "image/svg+xml"] },
        "checksum": { "type": "string", "pattern": "^(?:sha256:)?[a-f0-9]{64}$" },
        "provenance": { "type": "string", "minLength": 1, "maxLength": 500 },
        "rights": { "type": "string", "minLength": 1, "maxLength": 500 },
        "privateUse": { "type": "boolean" }
      }
    }
  }
}
