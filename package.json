{
  "name": "@rivallo/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format:check": "prettier --check package.json turbo.json pnpm-workspace.yaml scripts/*.mjs tooling-tests/*.mjs browser-tests/*.ts playwright.config.ts apps/desktop/package.json apps/desktop/vite.config.ts apps/desktop/index.html \"apps/desktop/src/**/*.{ts,tsx,css}\" apps/desktop/src-tauri/tauri.conf.json \"packages/design-tokens/src/**/*.{ts,css}\" \"packages/icons/src/**/*.{ts,tsx}\" \"data/**/*.{json,md}\" docs/adr/ADR-0014-world-package-patches-and-integrity.md \"docs/data-packages/*.md\" docker-compose.yml .github/workflows/ci.yml eslint.config.mjs vitest.config.mjs tsconfig.json .prettierrc.json",
    "lint": "eslint scripts tooling-tests browser-tests apps/desktop/src packages/design-tokens/src packages/icons/src eslint.config.mjs vitest.config.mjs playwright.config.ts --max-warnings 0",
    "quality": "node scripts/run-quality.mjs check",
    "quality:clean": "node scripts/verify-clean-worktree.mjs -- node scripts/run-quality.mjs clean-pass",
    "check": "node scripts/run-quality.mjs check",
    "browser:test": "playwright test",
    "components:test": "vitest run apps/desktop/src packages/icons/src",
    "contracts:openapi:generate": "node scripts/generate-openapi.mjs",
    "contracts:openapi:check": "node scripts/verify-openapi-drift.mjs",
    "contracts:client:generate": "node scripts/generate-contract-client.mjs",
    "contracts:client:check": "node scripts/verify-contract-client-drift.mjs",
    "desktop:build": "node scripts/build-desktop.mjs",
    "desktop:sidecar:prepare": "node scripts/build-desktop.mjs --prepare-sidecar-only",
    "rust:clippy": "node scripts/check-rust-quality.mjs clippy",
    "rust:fmt": "node scripts/check-rust-quality.mjs fmt",
    "rust:test": "node scripts/check-rust-quality.mjs test",
    "rust:architecture": "node scripts/verify-cargo-architecture.mjs",
    "smoke": "node scripts/run-quality.mjs",
    "test": "vitest run",
    "tokens:generate": "node scripts/generate-design-tokens.mjs",
    "tokens:check": "node scripts/verify-design-token-drift.mjs",
    "data:public-guard": "node scripts/verify-public-data-packages.mjs",
    "toolchains": "node scripts/check-toolchains.mjs",
    "typecheck": "tsc --noEmit",
    "ui-lab:test": "playwright test browser-tests/ui-lab.spec.ts"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "1.61.1",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "^9.31.0",
    "globals": "^16.0.0",
    "jsdom": "27.0.1",
    "orval": "8.21.0",
    "prettier": "^3.6.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.36.0",
    "vite": "8.1.4",
    "vitest": "^3.2.0"
  }
}
