{
  "name": "@rivallo/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format:check": "prettier --check package.json turbo.json pnpm-workspace.yaml scripts/*.mjs tooling-tests/*.mjs eslint.config.mjs vitest.config.mjs tsconfig.json .prettierrc.json",
    "lint": "eslint scripts tooling-tests eslint.config.mjs vitest.config.mjs --max-warnings 0",
    "quality": "pnpm smoke",
    "smoke": "node scripts/run-quality.mjs",
    "test": "vitest run tooling-tests/workspace-config.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.31.0",
    "globals": "^16.0.0",
    "prettier": "^3.6.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.0"
  }
}
