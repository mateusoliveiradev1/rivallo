{
  "name": "@rivallo/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format:check": "prettier --check package.json turbo.json pnpm-workspace.yaml scripts/*.mjs tooling-tests/*.mjs eslint.config.mjs vitest.config.mjs tsconfig.json .prettierrc.json",
    "lint": "eslint scripts tooling-tests eslint.config.mjs vitest.config.mjs --max-warnings 0",
    "quality": "pnpm smoke",
    "check": "node scripts/run-quality.mjs check",
    "contracts:openapi:generate": "node scripts/generate-openapi.mjs",
    "contracts:openapi:check": "node scripts/verify-openapi-drift.mjs",
    "contracts:client:generate": "node scripts/generate-contract-client.mjs",
    "contracts:client:check": "node scripts/verify-contract-client-drift.mjs",
    "rust:clippy": "node scripts/check-rust-quality.mjs clippy",
    "rust:fmt": "node scripts/check-rust-quality.mjs fmt",
    "rust:test": "node scripts/check-rust-quality.mjs test",
    "rust:architecture": "node scripts/verify-cargo-architecture.mjs",
    "smoke": "node scripts/run-quality.mjs",
    "test": "vitest run",
    "toolchains": "node scripts/check-toolchains.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.97.3",
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.31.0",
    "globals": "^16.0.0",
    "prettier": "^3.6.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.0"
  }
}
