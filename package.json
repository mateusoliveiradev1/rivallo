{
  "name": "@rivallo/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format:check": "prettier --check package.json turbo.json pnpm-workspace.yaml scripts/*.mjs tooling-tests/*.mjs apps/desktop/package.json apps/desktop/vite.config.ts apps/desktop/index.html apps/desktop/src/App.tsx apps/desktop/src/main.tsx apps/desktop/src/styles.css apps/desktop/src/react-runtime.d.ts apps/desktop/src-tauri/tauri.conf.json docker-compose.yml .github/workflows/ci.yml docs/operations/local-development.md eslint.config.mjs vitest.config.mjs tsconfig.json .prettierrc.json",
    "lint": "eslint scripts tooling-tests eslint.config.mjs vitest.config.mjs --max-warnings 0",
    "quality": "pnpm smoke",
    "check": "node scripts/run-quality.mjs check",
    "contracts:openapi:generate": "node scripts/generate-openapi.mjs",
    "contracts:openapi:check": "node scripts/verify-openapi-drift.mjs",
    "contracts:client:generate": "node scripts/generate-contract-client.mjs",
    "contracts:client:check": "node scripts/verify-contract-client-drift.mjs",
    "desktop:build": "node scripts/build-desktop.mjs",
    "desktop:sidecar:prepare": "node scripts/build-desktop.mjs --prepare-sidecar-only",
    "rust:clippy": "node scripts/check-rust-quality.mjs clippy",
    "rust:fmt": "node scripts/check-rust-quality.mjs fmt",
    "rust:test": "node scripts/check-rust-quality.mjs test",
    "rust:architecture": "node scripts/verify-cargo-architecture.mjs",
    "smoke": "node scripts/run-quality.mjs",
    "test": "vitest run",
    "toolchains": "node scripts/check-toolchains.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "1.61.1",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "^9.31.0",
    "globals": "^16.0.0",
    "jsdom": "27.0.1",
    "orval": "8.21.0",
    "prettier": "^3.6.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.36.0",
    "vite": "8.1.4",
    "vitest": "^3.2.0"
  }
}
