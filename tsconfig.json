{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "strict": true,
    "target": "ES2024",
    "types": ["node"]
  },
  "include": [
    "scripts/**/*.mjs",
    "tooling-tests/**/*.mjs",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/src/**/*.ts",
    "*.config.mjs"
  ]
}
